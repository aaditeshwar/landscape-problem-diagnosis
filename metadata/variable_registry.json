{
  "variable_registry": {
    "version": "1.0",
    "policy": "Canonical names match metadata/data_dictionary_v2.json. Framework and assembler may expose legacy aliases during migration; expressions should converge on canonical names and correct shapes.",
    "expression_access": {
      "nested_time_series": "Use year-keyed dict access, e.g. drought_causality[sorted(drought_causality.keys())[-1]]['mild']['spi_score']. Do not call .get() with invented flat keys like spi_class or spi_kharif.",
      "static": "Use the scalar directly, e.g. cd_urbanization_ha > 20. Do not index static variables with [-1] or [0]."
    },
