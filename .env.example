# Copy to .env and fill in values before running scripts.
CORE_STACK_API_KEY=
ANTHROPIC_API_KEY=
# Optional override (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional per-turn overrides (default to ANTHROPIC_MODEL)
# ANTHROPIC_REASON_MODEL=claude-sonnet-4-6
# ANTHROPIC_FOLLOWUP_MODEL=claude-sonnet-4-6
# ANTHROPIC_MAX_TOKENS=8192
# Reviewer diagnosis (server_review + independent_pathway_review) needs more headroom:
# ANTHROPIC_REVIEWER_MAX_TOKENS=16384
GOOGLE_MAPS_KEY=
MONGO_URI=mongodb://localhost:27017/?directConnection=true
UNPAYWALL_EMAIL=

# Diagnosis LLM provider: ollama (local GPU) or anthropic (Claude API)
LLM_PROVIDER=anthropic

# Ollama — chunking/embeddings; also used for diagnosis when LLM_PROVIDER=ollama
# Local default: http://localhost:11434
# GPU machine (must expose Ollama: set OLLAMA_HOST=0.0.0.0 on that host):
#   OLLAMA_URL=http://<gpu-machine-ip>:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_REASON_MODEL=qwen2.5:14b
OLLAMA_FOLLOWUP_MODEL=llama3.1:8b
OLLAMA_CHAT_TIMEOUT=600
OLLAMA_NUM_PREDICT=8192
OLLAMA_EMBED_CHAR_LIMIT=6000

# Server logging (relative paths resolve from repo root)
LOG_DIR=logs
LOG_LEVEL=INFO

# Open http://localhost:8000/api/logs/dashboard while the API is running

# Context cluster COG (signal editor map).
# Browser loads /api/clusters/cog; the API proxies this URL server-side (127.0.0.1 is fine here).
CLUSTER_COG_URL=http://100.102.70.41:10001/clusters.tif
CLUSTER_COG_VIEWER_URL=http://100.102.70.41:10001/raster.html

# Comma-separated reviewer names allowed to save triaging patches and finalize in revise-cards.
# Use ALL (default) to allow any non-empty reviewer name.
ALLOWED_REVIEWERS=ALL
