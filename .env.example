# Copy to .env and fill in values before running scripts.
CORE_STACK_API_KEY=
ANTHROPIC_API_KEY=
# Optional override (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6
GOOGLE_MAPS_KEY=
MONGO_URI=mongodb://localhost:27017/?directConnection=true
UNPAYWALL_EMAIL=

# Ollama — chunking/embeddings and runtime LLM calls
# Local default: http://localhost:11434
# GPU machine (must expose Ollama: set OLLAMA_HOST=0.0.0.0 on that host):
#   OLLAMA_URL=http://<gpu-machine-ip>:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_REASON_MODEL=qwen2.5:14b
OLLAMA_FOLLOWUP_MODEL=llama3.1:8b
OLLAMA_EMBED_CHAR_LIMIT=6000
